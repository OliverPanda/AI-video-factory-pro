{
  "name": "ai-video-factory-pro",
  "version": "1.0.0",
  "description": "AI漫剧自动化生成系统 - 输入剧本，自动生成短视频",
  "type": "module",
  "main": "scripts/run.js",
  "scripts": {
    "start": "node scripts/run.js",
    "resume:from-step": "node scripts/resume-from-step.js",
    "test": "node scripts/run-tests.js",
    "test:tts": "node scripts/run-tts-tests.js",
    "test:continuity": "node scripts/run-continuity-tests.js",
    "test:tts:keep-artifacts": "node scripts/run-tts-tests.js --keep-artifacts",
    "test:character-consistency": "node scripts/run-tests.js characterBible consistencyChecker.identity continuityChecker director.artifacts pipeline.acceptance characterConsistency.acceptance promptEngineer.artifacts",
    "test:script-parser:prod": "node scripts/run-agent-prod-tests.js script-parser",
    "test:script-parser:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js script-parser --keep-artifacts",
    "test:character-registry:prod": "node scripts/run-agent-prod-tests.js character-registry",
    "test:character-registry:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js character-registry --keep-artifacts",
    "test:prompt-engineer:prod": "node scripts/run-agent-prod-tests.js prompt-engineer",
    "test:prompt-engineer:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js prompt-engineer --keep-artifacts",
    "test:image-generator:prod": "node scripts/run-agent-prod-tests.js image-generator",
    "test:image-generator:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js image-generator --keep-artifacts",
    "test:consistency-checker:prod": "node scripts/run-agent-prod-tests.js consistency-checker",
    "test:consistency-checker:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js consistency-checker --keep-artifacts",
    "test:continuity-checker:prod": "node scripts/run-agent-prod-tests.js continuity-checker",
    "test:continuity-checker:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js continuity-checker --keep-artifacts",
    "test:tts-agent:prod": "node scripts/run-agent-prod-tests.js tts-agent",
    "test:tts-agent:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js tts-agent --keep-artifacts",
    "test:tts-qa:prod": "node scripts/run-agent-prod-tests.js tts-qa",
    "test:tts-qa:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js tts-qa --keep-artifacts",
    "test:lipsync-agent:prod": "node scripts/run-agent-prod-tests.js lipsync-agent",
    "test:lipsync-agent:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js lipsync-agent --keep-artifacts",
    "test:video-composer:prod": "node scripts/run-agent-prod-tests.js video-composer",
    "test:video-composer:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js video-composer --keep-artifacts",
    "test:director:prod": "node scripts/run-agent-prod-tests.js director",
    "test:director:prod:keep-artifacts": "node scripts/run-agent-prod-tests.js director --keep-artifacts",
    "test:pipeline:prod": "node --test tests/pipeline.acceptance.test.js",
    "test:agents:prod": "npm run test:script-parser:prod && npm run test:character-registry:prod && npm run test:prompt-engineer:prod && npm run test:image-generator:prod && npm run test:consistency-checker:prod && npm run test:continuity-checker:prod && npm run test:tts-agent:prod && npm run test:tts-qa:prod && npm run test:lipsync-agent:prod && npm run test:video-composer:prod && npm run test:director:prod && npm run test:pipeline:prod"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "p-queue": "^8.0.1",
    "sharp": "^0.33.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  }
}
