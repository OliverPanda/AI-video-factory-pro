# ============================================================
# AI漫剧自动化生成系统 - 环境变量配置示例
# ============================================================
# 用法：
# 1. 复制本文件为 .env
# 2. 按你的真实环境填写密钥和地址
# 3. 没有切换 provider 时，可先只填"必填"部分

# ============================================================
# 必填：当前默认主链路
# ============================================================

LLM_PROVIDER=qwen # 文本 LLM provider，当前默认 qwen
LLM_VISION_PROVIDER=qwen # 视觉理解 / 一致性检查 provider
QWEN_API_KEY=sk-xxx # Qwen API Key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 # Qwen 兼容 OpenAI 协议的基础地址

IMAGE_API_BASE_URL=https://api.laozhang.ai/v1 # 图像 API 基础地址（OpenAI 兼容协议）
IMAGE_API_KEY=sk-xxx # 图像 API Key

IMAGE_STYLE=realistic # 全局图片风格：realistic / anime / 3d

TTS_PROVIDER=minimax # TTS provider；可用 openai_compat 作为统一合同入口
TTS_TRANSPORT_PROVIDER=minimax # openai_compat 下的实际 TTS 供应商
MINIMAX_API_KEY= # MiniMax API Key
MINIMAX_GROUP_ID= # MiniMax GroupId；官方 HTTP TTS 常用查询参数
MINIMAX_TTS_BASE_URL=https://api.minimax.io # MiniMax TTS 基础地址
MINIMAX_TTS_REQUEST_PATH=/v1/t2a_v2 # MiniMax HTTP TTS 请求路径
MINIMAX_TTS_MODEL=speech-2.5-hd-preview # MiniMax 默认 TTS 模型
MINIMAX_TTS_VOICE= # 通用默认音色；留空时按男女声回退
MINIMAX_TTS_VOICE_FEMALE=Warm_Girl # 默认女性音色
MINIMAX_TTS_VOICE_MALE=Reliable_Executive # 默认男性音色
MINIMAX_TTS_AUDIO_FORMAT=mp3 # 输出音频格式
MINIMAX_TTS_SAMPLE_RATE=32000 # 输出采样率
MINIMAX_TTS_BITRATE=128000 # 输出码率
MINIMAX_TTS_CHANNEL=1 # 输出声道数
MINIMAX_TTS_SPEED=1 # 默认语速
MINIMAX_TTS_VOLUME=1 # 默认音量
MINIMAX_TTS_PITCH=0 # 默认音高
MINIMAX_TTS_EMOTION= # 可选情绪标签

# ============================================================
# 可选：切换文本 LLM Provider 时使用
# ============================================================

DEEPSEEK_API_KEY= # DeepSeek API Key；切到 deepseek 时才需要
DEEPSEEK_BASE_URL=https://api.deepseek.com # DeepSeek 基础地址
ANTHROPIC_API_KEY= # Anthropic API Key；切到 anthropic 时才需要

# ============================================================
# 可选：图像 / 编辑 / 视频模型路由
# ============================================================

IMAGE_TRANSPORT_PROVIDER=openai_compat # 图像 transport；默认 OpenAI 兼容 provider，也可切到 vercel_ai_gateway
REALISTIC_IMAGE_MODEL=flux-kontext-pro # 写实图像任务默认模型
THREED_IMAGE_MODEL=gpt-image-1 # 3D 图像任务默认模型
IMAGE_EDIT_MODEL=qwen-image-edit-max # 图像编辑任务默认模型
REALISTIC_VIDEO_MODEL=veo # 写实视频任务的抽象模型名
THREED_VIDEO_MODEL=sora # 3D 视频任务的抽象模型名

# ============================================================
# 可选：视频生成
# ============================================================

VIDEO_PROVIDER=seedance # 推荐保持 seedance；fallback_video 仅是历史兼容别名，不代表第二条链路
VIDEO_TRANSPORT_PROVIDER=seedance # 底层视频 transport；可选 seedance / sora2 / vercel_ai_gateway
VIDEO_FALLBACK_API_KEY= # 历史变量名；实际是在配置同一个主视频中转站 / relay 的 API Key
VIDEO_FALLBACK_BASE_URL= # 历史变量名；实际是同一个主视频中转站 / relay 基础地址（OpenAI 兼容）
VIDEO_FALLBACK_MODEL=doubao-seedance-2-0-260128 # 历史变量名；底层实际视频模型，shot / sequence / bridge 共用
VIDEO_FALLBACK_SIZE= # 可选覆盖；默认按 VIDEO_WIDTH/VIDEO_HEIGHT 智能推断，未设置时再按横竖屏回退
VIDEO_FALLBACK_SECONDS=5 # 单镜头默认秒数
VIDEO_FALLBACK_POLL_INTERVAL_MS=5000 # 轮询间隔（毫秒）
VIDEO_FALLBACK_TIMEOUT_MS=600000 # 超时（毫秒）
VIDEO_MODEL_SHOT=bytedance/seedance-v1.5-pro # Vercel AI Gateway 下单镜头默认模型
VIDEO_MODEL_SEQUENCE=bytedance/seedance-v1.5-pro # Vercel AI Gateway 下 sequence 默认模型
VIDEO_MODEL_BRIDGE=bytedance/seedance-v1.5-pro # Vercel AI Gateway 下 bridge 默认模型

# ============================================================
# 可选：Vercel AI Gateway 媒体中转层
# ============================================================

VERCEL_AI_GATEWAY_API_KEY= # 项目内适配层默认读取的 Vercel AI Gateway Key
AI_GATEWAY_API_KEY= # 官方常见变量名；若两者都填，优先读取 VERCEL_AI_GATEWAY_API_KEY
VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh # Vercel AI Gateway 基础地址
VERCEL_AI_GATEWAY_VIDEO_SUBMIT_PATH=/v1/video/generations # 视频提交路径（当前仓库适配层约定）
VERCEL_AI_GATEWAY_IMAGE_SUBMIT_PATH=/v1/images/generations # 图像提交路径（当前仓库适配层约定）

# ============================================================
# 可选：替换 TTS Provider 时使用
# ============================================================

XFYUN_TTS_APP_ID= # 讯飞 TTS App ID（仅历史兼容）
XFYUN_TTS_API_KEY= # 讯飞 TTS API Key（仅历史兼容）
XFYUN_TTS_API_SECRET= # 讯飞 TTS API Secret（仅历史兼容）
XFYUN_TTS_HOST=tts-api.xfyun.cn # 讯飞 TTS Host
XFYUN_TTS_PATH=/v2/tts # 讯飞 TTS 请求路径
XFYUN_TTS_VOICE= # 讯飞默认发音人
XFYUN_TTS_VOICE_FEMALE=xiaoyan # 讯飞女性角色默认发音人
XFYUN_TTS_VOICE_MALE=xiaofeng # 讯飞男性角色默认发音人
XFYUN_TTS_AUDIO_ENCODING=lame # 讯飞音频编码格式
XFYUN_TTS_AUDIO_FORMAT=audio/L16;rate=16000 # 讯飞音频输出 MIME / 采样率
XFYUN_TTS_TEXT_ENCODING=UTF8 # 讯飞文本编码

COSYVOICE_BASE_URL=http://127.0.0.1:50000 # CosyVoice 服务基础地址
COSYVOICE_MODE=sft # CosyVoice 推理模式
COSYVOICE_SPK_ID= # CosyVoice 说话人 ID
COSYVOICE_REQUEST_PATH= # CosyVoice 请求路径
FISH_SPEECH_BASE_URL=http://127.0.0.1:8080 # Fish Speech 服务基础地址
FISH_SPEECH_REQUEST_PATH=/v1/tts # Fish Speech 请求路径
FISH_SPEECH_API_KEY= # Fish Speech API Key
FISH_SPEECH_REFERENCE_ID= # Fish Speech 参考音色 ID
FISH_SPEECH_AUDIO_FORMAT=wav # Fish Speech 输出音频格式

# ============================================================
# 可选：ASR / 语音回写
# ============================================================

ASR_PROVIDER=mock # ASR provider；当前默认 mock

# ============================================================
# 可选：Lip-sync / 口型同步
# ============================================================

LIPSYNC_PROVIDER=mock # 口型同步 provider；当前默认 mock
LIPSYNC_FALLBACK_PROVIDERS= # 口型同步 fallback provider 列表，逗号分隔
FUNCINEFORGE_BASE_URL=http://127.0.0.1:7860 # FuncineForge 服务基础地址
FUNCINEFORGE_REQUEST_PATH=/v1/lipsync # FuncineForge 请求路径
FUNCINEFORGE_API_KEY= # FuncineForge API Key
FUNCINEFORGE_TIMEOUT_MS=30000 # FuncineForge 请求超时（毫秒）
FUNCINEFORGE_MAX_RETRIES=1 # FuncineForge 最大重试次数
FUNCINEFORGE_RETRY_DELAY_MS=500 # FuncineForge 重试间隔（毫秒）

# ============================================================
# 可选：运行与输出参数
# ============================================================

IMAGE_CONCURRENCY=2 # 图片生成并发数
VIDEO_CONCURRENCY=3 # 视频生成并发数（包括桥接和序列片段）
VIDEO_WIDTH=1080 # 最终视频宽度
VIDEO_HEIGHT=1920 # 最终视频高度
VIDEO_FPS=24 # 最终视频帧率
OUTPUT_DIR=./output # 最终输出目录
TEMP_DIR=./temp # 临时缓存目录
CONSISTENCY_THRESHOLD=7 # 一致性检查阈值，越高越严格
CONSISTENCY_BATCH_SIZE=6 # 一致性检查批大小
SUBTITLE_FONT= # 字幕字体；留空时使用系统默认字体
LOG_LEVEL=info # 日志级别
