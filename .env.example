# ============================================================
# AI漫剧自动化生成系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env，填入真实API Key

# ------------------------------------------------------------
# LLM 配置
# ------------------------------------------------------------
# 文本LLM提供商：deepseek | qwen | claude
LLM_PROVIDER=deepseek

# 视觉LLM提供商（一致性验证）：qwen | claude
LLM_VISION_PROVIDER=qwen

# DeepSeek API（主力文本LLM，推荐）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 API（文本备选 + 视觉验证）
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic Claude API（可选备用）
ANTHROPIC_API_KEY=sk-ant-xxx

# ------------------------------------------------------------
# 图像生成 API
# ------------------------------------------------------------
# 图像风格：realistic | 3d
IMAGE_STYLE=realistic

# 图像/视频主平台：当前默认仅支持老张中转站
PRIMARY_API_PROVIDER=laozhang
LAOZHANG_API_KEY=sk-xxx
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# 图像模型路由
REALISTIC_IMAGE_MODEL=flux-kontext-pro
THREED_IMAGE_MODEL=gpt-image-1
IMAGE_EDIT_MODEL=qwen-image-edit-max

# 视频模型路由（本轮先保留配置位，运行时暂未接入）
REALISTIC_VIDEO_MODEL=veo
THREED_VIDEO_MODEL=sora


# ------------------------------------------------------------
# TTS 配音 API
# ------------------------------------------------------------
# 讯飞在线语音合成（当前唯一支持）
XFYUN_TTS_APP_ID=xxx
XFYUN_TTS_API_KEY=xxx
XFYUN_TTS_API_SECRET=xxx
# WebSocket 接入点（通常不需要改）
XFYUN_TTS_HOST=tts-api.xfyun.cn
XFYUN_TTS_PATH=/v2/tts
# 默认/兜底发音人，仅在项目 voice preset 未指定时使用
XFYUN_TTS_VOICE=
XFYUN_TTS_VOICE_FEMALE=xiaoyan
XFYUN_TTS_VOICE_MALE=xiaofeng
# 编码与封装（通常保持默认）
XFYUN_TTS_AUDIO_ENCODING=lame
XFYUN_TTS_AUDIO_FORMAT=audio/L16;rate=16000
XFYUN_TTS_TEXT_ENCODING=UTF8

# ------------------------------------------------------------
# 其他配置
# ------------------------------------------------------------
# 并发图像生成数量（建议1-4）
IMAGE_CONCURRENCY=2

# 最终视频分辨率：1080x1920（竖屏）| 1920x1080（横屏）
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=24

# 输出目录
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 一致性验证评分阈值（低于此分数重新生成，1-10）
CONSISTENCY_THRESHOLD=7
# 一致性验证每批最多处理图片数（防止内存溢出）
CONSISTENCY_BATCH_SIZE=6

# 字幕字体（留空则自动检测系统字体）
# Windows 推荐：Microsoft YaHei | macOS：PingFang SC | Linux：Noto Sans CJK SC
SUBTITLE_FONT=

# 日志级别：debug | info | warn | error
LOG_LEVEL=info
