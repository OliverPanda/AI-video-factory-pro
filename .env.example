# ============================================================
# AI漫剧自动化生成系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env，填入真实API Key

# ------------------------------------------------------------
# LLM 配置
# ------------------------------------------------------------
# 文本LLM提供商：deepseek | qwen | claude
LLM_PROVIDER=deepseek

# 视觉LLM提供商（一致性验证）：qwen | claude
LLM_VISION_PROVIDER=qwen

# DeepSeek API（主力文本LLM，推荐）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 API（文本备选 + 视觉验证）
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic Claude API（可选备用）
ANTHROPIC_API_KEY=sk-ant-xxx

# ------------------------------------------------------------
# 图像生成 API
# ------------------------------------------------------------
# 图像风格：realistic | 3d
IMAGE_STYLE=realistic

# Together AI（写实风格，Flux Pro）
TOGETHER_API_KEY=xxx
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Stability AI（3D风格）
STABILITY_API_KEY=sk-xxx
STABILITY_BASE_URL=https://api.stability.ai

# ------------------------------------------------------------
# TTS 配音 API
# ------------------------------------------------------------
# TTS提供商：aliyun | azure | baidu
TTS_PROVIDER=aliyun

# 阿里云语音合成
ALIYUN_TTS_APP_KEY=xxx
ALIYUN_TTS_TOKEN=xxx
ALIYUN_TTS_BASE_URL=https://nls-gateway.cn-shanghai.aliyuncs.com

# Azure Speech（中文质量好）
AZURE_SPEECH_KEY=xxx
AZURE_SPEECH_REGION=eastasia

# ------------------------------------------------------------
# 其他配置
# ------------------------------------------------------------
# 并发图像生成数量（建议1-4）
IMAGE_CONCURRENCY=2

# 最终视频分辨率：1080x1920（竖屏）| 1920x1080（横屏）
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=24

# 输出目录
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 一致性验证评分阈值（低于此分数重新生成，1-10）
CONSISTENCY_THRESHOLD=7
# 一致性验证每批最多处理图片数（防止内存溢出）
CONSISTENCY_BATCH_SIZE=6

# 字幕字体（留空则自动检测系统字体）
# Windows 推荐：Microsoft YaHei | macOS：PingFang SC | Linux：Noto Sans CJK SC
SUBTITLE_FONT=
