# ============================================================
# AI漫剧自动化生成系统 - 环境变量配置示例
# ============================================================
# 用法：
# 1. 复制本文件为 .env
# 2. 按你的真实环境填写密钥和地址
# 3. 没有切换 provider 时，可先只填“必填”部分

# ============================================================
# 必填：当前默认主链路
# ============================================================

# 文本 LLM provider，当前默认使用 qwen。
LLM_PROVIDER=qwen

# 视觉理解 / 视觉一致性检查使用的 provider，当前默认使用 qwen。
LLM_VISION_PROVIDER=qwen

# Qwen API Key。
QWEN_API_KEY=sk-xxx

# Qwen 兼容 OpenAI 协议的基础地址。
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 图像主 provider，当前默认使用 laozhang。
PRIMARY_API_PROVIDER=laozhang

# 老张图像 / 通用模型平台的 API Key。
LAOZHANG_API_KEY=sk-xxx

# 老张平台基础地址。
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# 全局图片风格，常用 realistic / anime 等。
IMAGE_STYLE=realistic

# TTS provider，当前默认使用讯飞。
TTS_PROVIDER=xfyun

# 讯飞 TTS App ID。
XFYUN_TTS_APP_ID=xxx

# 讯飞 TTS API Key。
XFYUN_TTS_API_KEY=xxx

# 讯飞 TTS API Secret。
XFYUN_TTS_API_SECRET=xxx

# 讯飞 TTS Host。
XFYUN_TTS_HOST=tts-api.xfyun.cn

# 讯飞 TTS 请求路径。
XFYUN_TTS_PATH=/v2/tts

# 讯飞默认发音人；留空时由性别回退策略决定。
XFYUN_TTS_VOICE=

# 女性角色默认发音人。
XFYUN_TTS_VOICE_FEMALE=xiaoyan

# 男性角色默认发音人。
XFYUN_TTS_VOICE_MALE=xiaofeng

# 讯飞音频编码格式。
XFYUN_TTS_AUDIO_ENCODING=lame

# 讯飞音频输出 MIME / 采样率。
XFYUN_TTS_AUDIO_FORMAT=audio/L16;rate=16000

# 讯飞文本编码。
XFYUN_TTS_TEXT_ENCODING=UTF8

# ============================================================
# 可选：切换文本 LLM Provider 时使用
# ============================================================

# DeepSeek API Key；只有切到 deepseek 时才需要。
DEEPSEEK_API_KEY=

# DeepSeek 基础地址。
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic API Key；只有切到 anthropic 时才需要。
ANTHROPIC_API_KEY=

# ============================================================
# 可选：图像 / 编辑 / 视频模型路由
# ============================================================

# 写实图像任务默认模型。
REALISTIC_IMAGE_MODEL=flux-kontext-pro

# 3D 图像任务默认模型。
THREED_IMAGE_MODEL=gpt-image-1

# 图像编辑任务默认模型。
IMAGE_EDIT_MODEL=qwen-image-edit-max

# 写实视频任务的抽象模型名，供上层策略路由使用。
REALISTIC_VIDEO_MODEL=veo

# 3D 视频任务的抽象模型名，供上层策略路由使用。
THREED_VIDEO_MODEL=sora

# ============================================================
# 可选：Fallback Video 通用配置
# ============================================================

# 视频主 provider；seedance 为主路径，fallback_video 为兼容视频路径。
VIDEO_PROVIDER=seedance

# Fallback Video 的 API Key。
VIDEO_FALLBACK_API_KEY=

# Fallback Video 的基础地址。
VIDEO_FALLBACK_BASE_URL=https://api.laozhang.ai/v1

# Fallback Video 主模型。
VIDEO_FALLBACK_MODEL=veo-3.0-fast-generate-001

# Fallback Video 通用候选模型列表，逗号分隔；通常留空即可。
VIDEO_FALLBACK_MODEL_CANDIDATES=

# Fallback Video 请求尺寸。
VIDEO_FALLBACK_SIZE=720x1280

# 单镜头 fallback video 默认请求秒数。
VIDEO_FALLBACK_SECONDS=4

# Fallback Video 轮询间隔，单位毫秒。
VIDEO_FALLBACK_POLL_INTERVAL_MS=5000

# Fallback Video 整体超时，单位毫秒。
VIDEO_FALLBACK_TIMEOUT_MS=300000

# Sequence 专用固定请求秒数；留空时按 sequence 自身目标时长申请。
VIDEO_FALLBACK_SEQUENCE_SECONDS=

# Sequence 专用候选模型列表，逗号分隔。
VIDEO_FALLBACK_SEQUENCE_MODEL_CANDIDATES=grok-video-3

# Sequence 对同一请求的有限重试次数。
VIDEO_FALLBACK_SEQUENCE_RETRY_ATTEMPTS=2

# ============================================================
# 可选：Seedance / 火山方舟视频生成
# ============================================================

# 火山方舟 API Key；能用时优先复用。
ARK_API_KEY=

# Seedance 单独 API Key；如不填可走 ARK_API_KEY。
SEEDANCE_API_KEY=

# Seedance API 基础地址。
SEEDANCE_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Seedance 模型 ID。
SEEDANCE_MODEL_ID=doubao-seedance-2-0-260128

# Seedance 默认画幅比例。
SEEDANCE_VIDEO_RATIO=9:16

# Seedance 默认目标时长，单位秒。
SEEDANCE_DEFAULT_DURATION_SEC=5

# Seedance 轮询间隔，单位毫秒。
SEEDANCE_POLL_INTERVAL_MS=10000

# Seedance 整体超时，单位毫秒。
SEEDANCE_TIMEOUT_MS=600000

# ============================================================
# 可选：替换 TTS Provider 时使用
# ============================================================

# CosyVoice 服务基础地址。
COSYVOICE_BASE_URL=http://127.0.0.1:50000

# CosyVoice 推理模式。
COSYVOICE_MODE=sft

# CosyVoice 说话人 ID。
COSYVOICE_SPK_ID=

# CosyVoice 请求路径。
COSYVOICE_REQUEST_PATH=

# Fish Speech 服务基础地址。
FISH_SPEECH_BASE_URL=http://127.0.0.1:8080

# Fish Speech 请求路径。
FISH_SPEECH_REQUEST_PATH=/v1/tts

# Fish Speech API Key。
FISH_SPEECH_API_KEY=

# Fish Speech 参考音色 ID。
FISH_SPEECH_REFERENCE_ID=

# Fish Speech 输出音频格式。
FISH_SPEECH_AUDIO_FORMAT=wav

# ============================================================
# 可选：ASR / 语音回写
# ============================================================

# ASR provider；当前默认 mock。
ASR_PROVIDER=mock

# ============================================================
# 可选：Lip-sync / 口型同步
# ============================================================

# 口型同步 provider；当前默认 mock。
LIPSYNC_PROVIDER=mock

# 口型同步 fallback provider 列表，逗号分隔。
LIPSYNC_FALLBACK_PROVIDERS=

# FuncineForge 服务基础地址。
FUNCINEFORGE_BASE_URL=http://127.0.0.1:7860

# FuncineForge 请求路径。
FUNCINEFORGE_REQUEST_PATH=/v1/lipsync

# FuncineForge API Key。
FUNCINEFORGE_API_KEY=

# FuncineForge 请求超时，单位毫秒。
FUNCINEFORGE_TIMEOUT_MS=30000

# FuncineForge 最大重试次数。
FUNCINEFORGE_MAX_RETRIES=1

# FuncineForge 重试间隔，单位毫秒。
FUNCINEFORGE_RETRY_DELAY_MS=500

# ============================================================
# 可选：运行与输出参数
# ============================================================

# 图片生成并发数。
IMAGE_CONCURRENCY=2

# 最终视频宽度。
VIDEO_WIDTH=1080

# 最终视频高度。
VIDEO_HEIGHT=1920

# 最终视频帧率。
VIDEO_FPS=24

# 最终输出目录。
OUTPUT_DIR=./output

# 临时缓存目录。
TEMP_DIR=./temp

# 一致性检查阈值，越高越严格。
CONSISTENCY_THRESHOLD=7

# 一致性检查批大小。
CONSISTENCY_BATCH_SIZE=6

# 字幕字体；留空时使用系统默认字体。
SUBTITLE_FONT=

# 日志级别。
LOG_LEVEL=info
