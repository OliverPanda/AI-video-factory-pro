# ============================================================
# AI漫剧自动化生成系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env，填入真实配置
#
# 当前默认主链路：
# - 文本 LLM：qwen
# - 视觉一致性：qwen
# - 图像平台：laozhang
# - TTS：xfyun
#
# 按当前代码和启动校验逻辑，下面“必填”部分缺一不可。

# ------------------------------------------------------------
# 必填：当前默认主链路必须配置
# ------------------------------------------------------------

# 文本 / 视觉 LLM
LLM_PROVIDER=qwen
LLM_VISION_PROVIDER=qwen
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 图像生成
PRIMARY_API_PROVIDER=laozhang
LAOZHANG_API_KEY=sk-xxx
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1
IMAGE_STYLE=realistic

# TTS 配音
TTS_PROVIDER=xfyun
XFYUN_TTS_APP_ID=xxx
XFYUN_TTS_API_KEY=xxx
XFYUN_TTS_API_SECRET=xxx
XFYUN_TTS_HOST=tts-api.xfyun.cn
XFYUN_TTS_PATH=/v2/tts
XFYUN_TTS_VOICE=
XFYUN_TTS_VOICE_FEMALE=xiaoyan
XFYUN_TTS_VOICE_MALE=xiaofeng
XFYUN_TTS_AUDIO_ENCODING=lame
XFYUN_TTS_AUDIO_FORMAT=audio/L16;rate=16000
XFYUN_TTS_TEXT_ENCODING=UTF8

# ------------------------------------------------------------
# 可选：切换文本 LLM Provider 时再配置
# ------------------------------------------------------------

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# 可选：切换图像 / 编辑 / 视频路由时使用
# ------------------------------------------------------------

REALISTIC_IMAGE_MODEL=flux-kontext-pro
THREED_IMAGE_MODEL=gpt-image-1
IMAGE_EDIT_MODEL=qwen-image-edit-max
REALISTIC_VIDEO_MODEL=veo
THREED_VIDEO_MODEL=sora

# ------------------------------------------------------------
# 可选：切换 TTS Provider 时使用
# 注意：当前启动校验仍默认要求讯飞必填项存在
# ------------------------------------------------------------

COSYVOICE_BASE_URL=http://127.0.0.1:50000
COSYVOICE_MODE=sft
COSYVOICE_SPK_ID=
COSYVOICE_REQUEST_PATH=

FISH_SPEECH_BASE_URL=http://127.0.0.1:8080
FISH_SPEECH_REQUEST_PATH=/v1/tts
FISH_SPEECH_API_KEY=
FISH_SPEECH_REFERENCE_ID=
FISH_SPEECH_AUDIO_FORMAT=wav

# ------------------------------------------------------------
# 可选：ASR / 语音回写
# ------------------------------------------------------------

ASR_PROVIDER=mock

# ------------------------------------------------------------
# 可选：Lip-sync / 口型同步
# 默认 mock 不需要 key
# ------------------------------------------------------------

LIPSYNC_PROVIDER=mock
LIPSYNC_FALLBACK_PROVIDERS=

FUNCINEFORGE_BASE_URL=http://127.0.0.1:7860
FUNCINEFORGE_REQUEST_PATH=/v1/lipsync
FUNCINEFORGE_API_KEY=
FUNCINEFORGE_TIMEOUT_MS=30000
FUNCINEFORGE_MAX_RETRIES=1
FUNCINEFORGE_RETRY_DELAY_MS=500

# ------------------------------------------------------------
# 可选：运行与输出参数
# ------------------------------------------------------------

IMAGE_CONCURRENCY=2

VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=24

OUTPUT_DIR=./output
TEMP_DIR=./temp

CONSISTENCY_THRESHOLD=7
CONSISTENCY_BATCH_SIZE=6

SUBTITLE_FONT=
LOG_LEVEL=info
